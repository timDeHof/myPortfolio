# EmailJS Configuration
# Get these values from your EmailJS dashboard at https://www.emailjs.com/
VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_AUTO_REPLY_TEMPLATE_ID=your_auto_reply_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# GitHub Personal Access Token
# Generate this from GitHub Settings > Developer settings > Personal access tokens
# Requires 'public_repo' scope for accessing public repositories
VITE_GITHUB_PAT=your_github_personal_access_token_here
VITE_API_BASE_URL=https://portfolio-api.ttdehof.workers.dev/api

# Resume PDF URL
# Upload your resume to Cloudflare R2 and add the public URL here
# The resume button will only show when this is configured
VITE_RESUME_URL=https://your-bucket.r2.cloudflarestorage.com/resume.pdf